# Trumpet AI Teaching Lab — environment template.
# Copy to teaching-engine/.env and fill in. The real .env is gitignored.
# Leave USE_MOCK=true to run the app with deterministic placeholder responses
# (no API key, no cost).

# Anthropic API (required only when USE_MOCK=false)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Mock mode: true = no live LLM calls (recommended for local demo)
USE_MOCK=true

# Paths (defaults are fine for local dev)
VECTOR_DB_PATH=data/vector_db/
AUDIO_UPLOAD_DIR=uploads/audio/

# Limits
MAX_CONVERSATION_HISTORY=10
MAX_AUDIO_SIZE_MB=10

LOG_LEVEL=INFO
